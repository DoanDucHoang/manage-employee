{
  "name": "my-node-crud",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "ts-node-dev --respawn --transpile-only --exit-child --poll src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "db-migrate up --env dev",
    "migrate:down": "db-migrate down --env dev",
    "migrate:create": "db-migrate create"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "formidable": "^3.5.4",
    "mysql": "^2.18.1",
    "mysql2": "^3.14.1",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@types/formidable": "^3.4.5",
    "@types/mysql": "^2.15.27",
    "@types/node": "^20.11.0",
    "db-migrate": "^0.11.14",
    "db-migrate-mysql": "^3.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
